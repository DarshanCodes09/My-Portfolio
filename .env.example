# Site URL (required — use your Vercel domain in production)
NEXT_PUBLIC_URL=http://127.0.0.1:3000

# Telegram — contact form delivery
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Spotify now-playing widget
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Add redirect URI: https://YOUR-DOMAIN.vercel.app/api/spotify/callback
# 3. Get refresh token via /spotify-setup or https://spotify-refresh-token-generator.netlify.app
# 4. On Vercel: add ALL THREE below in Settings → Environment Variables → Redeploy
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# Optional: override callback URL if NEXT_PUBLIC_URL differs from Spotify redirect
# SPOTIFY_REDIRECT_URI=https://your-domain.vercel.app/api/spotify/callback

# Optional: Umami analytics
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_URL=
